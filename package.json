{
  "name": "konfuz",
  "version": "1.0.0",
  "description": "Configuration management library for NPM applications using Zod schemas",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "main": "./dist/index.mjs",
    "import": "./dist/index.mjs",
    "types": "./dist/index.d.mts"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "oxlint",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "config",
    "configuration",
    "zod",
    "env",
    "environment",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "dotenv": "^17.0.0",
    "yargs": "^18.0.0"
  },
  "peerDependencies": {
    "zod": ">=4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^4.1.3",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3",
    "zod": "^4.3.6"
  }
}