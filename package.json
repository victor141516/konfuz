{
  "name": "parse-my-conf",
  "version": "1.0.0",
  "description": "Configuration management library for NPM applications using Zod schemas",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "config",
    "configuration",
    "zod",
    "env",
    "environment",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "peerDependencies": {
    "zod": ">=3"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^3.0.0",
    "dotenv": "^16.5.0",
    "oxlint": "^0.16.0",
    "prettier": "^3.5.0",
    "tsdown": "^0.21.7",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0",
    "yargs": "^18.0.0",
    "zod": "^3.24.0"
  }
}